{
  "name": "paybridge-playground-root",
  "version": "0.2.0",
  "private": true,
  "workspaces": [
    "frontend",
    "backend"
  ],
  "scripts": {
    "dev:frontend": "npm -w frontend run dev",
    "dev:backend": "npm -w backend run dev",
    "build": "npm -w frontend run build && npm -w backend run build",
    "start": "npm -w backend run start",
    "test": "npm -w backend test"
  },
  "description": "Live, working demo of PayBridge - unified payment SDK",
  "repository": {
    "type": "git",
    "url": "https://github.com/kobie3717/paybridge-playground"
  },
  "keywords": [
    "paybridge",
    "payments",
    "playground",
    "demo",
    "south-africa"
  ],
  "author": "Kobie Theron",
  "license": "MIT",
  "dependencies": {
    "@tailwindcss/postcss": "^4.2.4",
    "@types/express": "^5.0.6",
    "@types/node": "^25.6.0",
    "@vitejs/plugin-react": "^6.0.1",
    "autoprefixer": "^10.5.0",
    "eslint": "^10.3.0",
    "express": "^5.2.1",
    "paybridge": "1.0.0-rc.2",
    "postcss": "^8.5.13",
    "tailwindcss": "^4.2.4",
    "tsx": "^4.21.0",
    "typescript": "^6.0.3",
    "vite": "^8.0.10"
  }
}
